<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MessageOnline" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/wa_dark_green</item>
        <item name="colorOnPrimary">@color/wa_white</item>
        <item name="colorPrimaryContainer">@color/wa_bubble_sent</item>
        <item name="colorOnPrimaryContainer">@color/wa_text_dark</item>
        <item name="colorSecondary">@color/wa_light_green</item>
        <item name="colorOnSecondary">@color/wa_white</item>
        <item name="colorSecondaryContainer">@color/wa_bubble_received</item>
        <item name="colorOnSecondaryContainer">@color/wa_text_dark</item>
        <item name="colorSurface">@color/wa_white</item>
        <item name="colorOnSurface">@color/wa_text_dark</item>
        <item name="android:colorBackground">@color/wa_white</item>
        <item name="android:statusBarColor">@color/wa_header</item>
        <item name="android:navigationBarColor">@color/wa_bottom_bar</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.MessageOnline.Dialog</item>
    </style>

    <style name="ThemeOverlay.MessageOnline.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/wa_dark_green</item>
        <item name="colorSurface">@color/wa_white</item>
        <item name="android:colorBackground">@color/wa_white</item>
    </style>
</resources>
