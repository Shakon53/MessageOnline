<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="#1A2236"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#26FFFFFF"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <!-- Avatar with online dot -->
        <FrameLayout
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginEnd="12dp">

            <View
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/avatar_circle_bg" />

            <TextView
                android:id="@+id/tvFriendInitial"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivFriendAvatar"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <View
                android:id="@+id/vOnlineDot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/shape_online_dot"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Name + status -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvFriendName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFriendStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Chat button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartChat"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Чат"
            android:textSize="12sp"
            android:layout_marginEnd="8dp"
            app:backgroundTint="#1A6366F1"
            app:cornerRadius="10dp"
            app:icon="@drawable/ic_message"
            app:iconSize="14dp"
            app:iconPadding="4dp" />

        <!-- Remove button -->
        <ImageView
            android:id="@+id/btnRemoveFriend"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="8dp"
            android:src="@drawable/ic_close"
            android:tint="#475569"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Удалить" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
