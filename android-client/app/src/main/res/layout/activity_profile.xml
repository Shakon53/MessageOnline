<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Зелёная шапка с аватаром -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#075E54"
            android:padding="16dp">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:layout_gravity="top"
                app:navigationIcon="@drawable/ic_back"
                app:title="Профиль"
                app:titleTextColor="#FFFFFF"
                app:navigationIconTint="#FFFFFF" />

            <!-- Цветной круг с инициалами -->
            <FrameLayout
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_marginTop="8dp">

                <View
                    android:id="@+id/avatarCircle"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:background="@drawable/avatar_circle_bg" />

                <TextView
                    android:id="@+id/tvAvatarInitial"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textSize="36sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </FrameLayout>

        </LinearLayout>

        <!-- Карточка с данными профиля -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Имя пользователя -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Имя"
                    android:textSize="12sp"
                    android:textColor="#075E54"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textColor="#212121"
                    android:paddingTop="4dp"
                    android:paddingBottom="16dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0" />

                <!-- Телефон -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Телефон"
                    android:textSize="12sp"
                    android:textColor="#075E54"
                    android:letterSpacing="0.1"
                    android:paddingTop="16dp" />

                <TextView
                    android:id="@+id/tvPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="#212121"
                    android:paddingTop="4dp"
                    android:paddingBottom="16dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0" />

                <!-- Статус (редактируемый) -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="О себе"
                    android:textSize="12sp"
                    android:textColor="#075E54"
                    android:letterSpacing="0.1"
                    android:paddingTop="16dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:boxStrokeColor="#075E54"
                    app:hintTextColor="#075E54"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etStatusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxLength="140"
                        android:maxLines="3"
                        android:inputType="textMultiLine"
                        android:hint="Введите статус..." />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/tvCharCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="4dp"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E"
                    android:text="0/140" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Кнопка сохранить -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:text="Сохранить"
            android:textSize="16sp"
            android:backgroundTint="#25D366"
            android:textColor="#FFFFFF"
            app:cornerRadius="28dp" />

    </LinearLayout>
</ScrollView>
