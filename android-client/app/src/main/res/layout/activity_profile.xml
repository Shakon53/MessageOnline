<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ft_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Gradient Header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/bg_profile_header">

            <!-- Toolbar inside header -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:layout_gravity="top"
                android:paddingTop="24dp"
                app:navigationIcon="@drawable/ic_back"
                app:navigationIconTint="#FFFFFF"
                app:title="Профиль"
                app:titleTextColor="#FFFFFF" />

            <!-- Avatar centered + clickable to change -->
            <FrameLayout
                android:id="@+id/flAvatarContainer"
                android:layout_width="104dp"
                android:layout_height="104dp"
                android:layout_gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <!-- Avatar background ring -->
                <View
                    android:layout_width="104dp"
                    android:layout_height="104dp"
                    android:background="@drawable/bg_avatar_ring" />

                <!-- Avatar image -->
                <ImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="92dp"
                    android:layout_height="92dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:background="@drawable/avatar_circle_bg"
                    android:visibility="gone"
                    android:contentDescription="@null" />

                <!-- Initial letter -->
                <TextView
                    android:id="@+id/tvAvatarInitial"
                    android:layout_width="92dp"
                    android:layout_height="92dp"
                    android:layout_gravity="center"
                    android:background="@drawable/avatar_circle_bg"
                    android:gravity="center"
                    android:textSize="38sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <!-- Camera badge (bottom-right) -->
                <FrameLayout
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="2dp"
                    android:layout_marginBottom="2dp"
                    android:background="@drawable/bg_camera_badge">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_camera"
                        android:tint="#FFFFFF"
                        android:contentDescription="@null" />
                </FrameLayout>

            </FrameLayout>

            <!-- "Нажмите для изменения" hint -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="12dp"
                android:text="Нажмите на фото, чтобы изменить"
                android:textColor="#80FFFFFF"
                android:textSize="11sp" />

        </FrameLayout>

        <!-- Profile Info Glass Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="@drawable/bg_glass_card"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Name section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ИМЯ"
                android:textSize="11sp"
                android:textColor="#6366F1"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:paddingTop="6dp"
                android:paddingBottom="4dp" />

            <!-- ID row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tvUserId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#6366F1"
                    android:text="ID: #—" />

                <ImageView
                    android:id="@+id/ivCopyId"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_copy"
                    android:tint="#4B5563"
                    android:contentDescription="@null" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1AFFFFFF" />

            <!-- Email section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EMAIL"
                android:textSize="11sp"
                android:textColor="#6366F1"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:paddingTop="20dp" />

            <TextView
                android:id="@+id/tvPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#94A3B8"
                android:paddingTop="6dp"
                android:paddingBottom="20dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1AFFFFFF" />

            <!-- Status section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="О СЕБЕ"
                android:textSize="11sp"
                android:textColor="#6366F1"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:paddingTop="20dp"
                android:paddingBottom="10dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Введите статус..."
                app:boxBackgroundColor="#111827"
                app:boxStrokeColor="#26FFFFFF"
                app:boxStrokeWidth="1dp"
                app:hintTextColor="#64748B"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLength="140"
                    android:maxLines="3"
                    android:inputType="textMultiLine"
                    android:textColor="#FFFFFF" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tvCharCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="6dp"
                android:textSize="12sp"
                android:textColor="#64748B"
                android:text="0/140" />
        </LinearLayout>

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="24dp"
            android:text="Сохранить"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:backgroundTint="#6366F1"
            app:cornerRadius="16dp" />

    </LinearLayout>
</ScrollView>
