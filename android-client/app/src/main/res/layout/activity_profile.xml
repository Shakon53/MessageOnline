<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ft_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Gradient Header — avatar + name + status + stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_profile_header"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:paddingTop="24dp"
                app:navigationIcon="@drawable/ic_back"
                app:navigationIconTint="#FFFFFF"
                app:title="Профиль"
                app:titleTextColor="#FFFFFF" />

            <FrameLayout
                android:id="@+id/flAvatarContainer"
                android:layout_width="104dp"
                android:layout_height="104dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <View
                    android:layout_width="104dp"
                    android:layout_height="104dp"
                    android:background="@drawable/bg_avatar_ring" />

                <ImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="92dp"
                    android:layout_height="92dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:background="@drawable/avatar_circle_bg"
                    android:visibility="gone"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tvAvatarInitial"
                    android:layout_width="92dp"
                    android:layout_height="92dp"
                    android:layout_gravity="center"
                    android:background="@drawable/avatar_circle_bg"
                    android:gravity="center"
                    android:textSize="38sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="2dp"
                    android:layout_marginBottom="2dp"
                    android:background="@drawable/bg_camera_badge">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_camera"
                        android:tint="#FFFFFF"
                        android:contentDescription="@null" />
                </FrameLayout>

                <!-- Online indicator dot -->
                <View
                    android:id="@+id/viewOnlineDot"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_online_dot" />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="5dp"
                android:text="Нажмите на фото, чтобы изменить"
                android:textColor="#60FFFFFF"
                android:textSize="11sp" />

            <!-- Username + edit pencil -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <ImageView
                    android:id="@+id/ibEditUsername"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_edit_compose"
                    android:tint="#70FFFFFF"
                    android:padding="2dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Изменить имя" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvHeaderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="3dp"
                android:textColor="#80FFFFFF"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvMemberSince"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:drawablePadding="4dp"
                android:textColor="#50FFFFFF"
                android:textSize="11sp" />

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="18dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_stat_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_marginEnd="10dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/tvStatFriends"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Друзья"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_stat_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/tvStatMessages"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Сообщений"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- Profile Info Glass Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="@drawable/bg_glass_card"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- ID row with QR button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvUserId"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textColor="#6366F1"
                    android:text="ID: #—" />

                <ImageView
                    android:id="@+id/ivCopyId"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_copy"
                    android:tint="#4B5563"
                    android:contentDescription="@null" />

                <!-- QR button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShowQR"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="QR"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="12dp"
                    app:backgroundTint="#1E6366F1"
                    app:strokeColor="#336366F1"
                    app:strokeWidth="1dp"
                    app:cornerRadius="10dp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1AFFFFFF" />

            <!-- Email section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EMAIL"
                android:textSize="11sp"
                android:textColor="#6366F1"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:paddingTop="20dp" />

            <TextView
                android:id="@+id/tvPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#94A3B8"
                android:paddingTop="6dp"
                android:paddingBottom="20dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1AFFFFFF" />

            <!-- Status section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="О СЕБЕ"
                android:textSize="11sp"
                android:textColor="#6366F1"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:paddingTop="20dp"
                android:paddingBottom="10dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Введите статус..."
                app:boxBackgroundColor="#111827"
                app:boxStrokeColor="#26FFFFFF"
                app:boxStrokeWidth="1dp"
                app:hintTextColor="#64748B"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLength="140"
                    android:maxLines="3"
                    android:inputType="textMultiLine"
                    android:textColor="#FFFFFF" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tvCharCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="6dp"
                android:textSize="12sp"
                android:textColor="#64748B"
                android:text="0/140" />
        </LinearLayout>

        <!-- Settings card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_glass_card"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="8dp">

            <!-- Section label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="НАСТРОЙКИ"
                android:textSize="11sp"
                android:textColor="#6366F1"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:paddingTop="16dp"
                android:paddingBottom="12dp" />

            <!-- DND row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Не беспокоить"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Отключить уведомления"
                        android:textColor="#4B5563"
                        android:textSize="12sp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchDND"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1AFFFFFF" />

            <!-- Privacy row -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Кто может писать вам"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:paddingTop="14dp"
                android:paddingBottom="8dp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/togglePrivacy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <Button
                    android:id="@+id/btnPrivacyAll"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:text="Все"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    app:strokeColor="#336366F1" />

                <Button
                    android:id="@+id/btnPrivacyFriends"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:text="Только друзья"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    app:strokeColor="#336366F1" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

        </LinearLayout>

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            android:text="Сохранить"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:backgroundTint="#6366F1"
            app:cornerRadius="16dp" />

        <!-- Logout button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="32dp"
            android:text="Выйти из аккаунта"
            android:textSize="14sp"
            android:textColor="#FF5C8D"
            app:strokeColor="#33FF5C8D"
            app:cornerRadius="16dp" />

    </LinearLayout>
</ScrollView>
